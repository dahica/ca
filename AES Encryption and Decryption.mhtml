b + "&lt;br&gt;");

// Gets the generated key
y =3D power(G, b, P);

// Generating the secret key after the exchange
// of keys
ka =3D power(y, a, P); // Secret key for Alice
kb =3D power(x, b, P); // Secret key for Bob

document.write("Secret key for the Alice is:" +
ka + "&lt;br&gt;");
