			val =3D sbox[j][row][col]
			sbox_str =3D sbox_str + dec2bin(val)

		# Straight D-box: After substituting rearranging the bits
		sbox_str =3D permute(sbox_str, per, 32)

		# XOR left and sbox_str
		result =3D xor(left, sbox_str)
		left =3D result

		# Swapper
		if(i !=3D 15):
			left, right =3D right, left
		print("Round ", i + 1, " ", bin2hex(left),
			" ", bin2hex(right), " ", rk[i])

	# Combination
	combine =3D left + right

	# Final permutation: final rearranging of bits to get cipher text
	cipher_text =3D permute(combine, final_perm, 64)
	return cipher_text


pt =3D "123456ABCD132536"
key =3D "AABB09182736CCDD"

# Key generation
# --hex to binary
key =3D hex2bin(key)

# --parity bit drop table
keyp =3D [57, 49, 41, 33, 25, 17, 9,
		1, 58, 50, 42, 34, 26, 18,
		10, 2, 59, 51, 43, 35, 27,
		19, 11, 3, 60, 52, 44, 36,
		63, 55, 47, 39, 31, 23, 15,
		7, 62, 54, 46, 38, 30, 22,
		14, 6, 61, 53, 45, 37, 29,
		21, 13, 5, 28, 20, 12, 4]

# getting 56 bit key from 64 bit using the parity bits
key =3D permute(key, keyp, 56)

# Number of bit shifts
shift_table =3D [1, 1, 2, 2,
			2, 2, 2, 2,
			1, 2, 2, 2,
			2, 2, 2, 1]

# Key- Compression Table : Compression of key from 56 bits to 48 bits
key_comp =3D [14, 17, 11, 24, 1, 5,
			3, 28, 15, 6, 21, 10,
			23, 19, 12, 4, 26, 8,
			16, 7, 27, 20, 13, 2,
			41, 52, 31, 37, 47, 55,
			30, 40, 51, 45, 33, 48,
			44, 49, 39, 56, 34, 53,
			46, 42, 50, 36, 29, 32]

# Splitting
left =3D key[0:28] # rkb for RoundKeys in binary
right =3D key[28:56] # rk for RoundKeys in hexadecimal

rkb =3D []
rk =3D []
for i in range(0, 16):
	# Shifting the bits by nth shifts by checking from shift table
	left =3D shift_left(left, shift_table[i])
	right =3D shift_left(right, shift_table[i])

	# Combination of left and right string
	combine_str =3D left + right

	# Compression of key from 56 to 48 bits
	round_key =3D permute(combine_str, key_comp, 48)

	rkb.append(round_key)
	rk.append(bin2hex(round_key))

print("Encryption")
cipher_text =3D bin2hex(encrypt(pt, rkb, rk))
print("Cipher Text : ", cipher_text)

print("Decryption")
rkb_rev =3D rkb[::-1]
rk_rev =3D rk[::-1]
text =3D bin2hex(encrypt(cipher_text, rkb_rev, rk_rev))
print("Plain Text : ", text)

