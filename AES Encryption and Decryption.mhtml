# Hexadecimal to binary conversion


def hex2bin(s):
	mp =3D {'0': "0000",
		'1': "0001",
		'2': "0010",
		'3': "0011",
		'4': "0100",
		'5': "0101",
		'6': "0110",
		'7': "0111",
		'8': "1000",
		'9': "1001",
		'A': "1010",
		'B': "1011",
		'C': "1100",
		'D': "1101",
		'E': "1110",
		'F': "1111"}
	bin =3D ""
	for i in range(len(s)):
		bin =3D bin + mp[s[i]]
	return bin

# Binary to hexadecimal conversion


def bin2hex(s):
	mp =3D {"0000": '0',
		"0001": '1',
		"0010": '2',
		"0011": '3',
		"0100": '4',
		"0101": '5',
		"0110": '6',
		"0111": '7',
		"1000": '8',
		"1001": '9',
		"1010": 'A',
		"1011": 'B',
		"1100": 'C',
		"1101": 'D',
		"1110": 'E',
		"1111": 'F'}
	hex =3D ""
	for i in range(0, len(s), 4):
		ch =3D ""
		ch =3D ch + s[i]
		ch =3D ch + s[i + 1]
		ch =3D ch + s[i + 2]
		ch =3D ch + s[i + 3]
		hex =3D hex + mp[ch]

	return hex

# Binary to decimal conversion


def bin2dec(binary):

	binary1 =3D binary
	decimal, i, n =3D 0, 0, 0
	while(binary !=3D 0):
		dec =3D binary % 10
		decimal =3D decimal + dec * pow(2, i)
		binary =3D binary//10
		i +=3D 1
	return decimal

# Decimal to binary conversion


def dec2bin(num):
	res =3D bin(num).replace("0b", "")
	if(len(res) % 4 !=3D 0):
		div =3D len(res) / 4
		div =3D int(div)
		counter =3D (4 * (div + 1)) - len(res)
		for i in range(0, counter):
			res =3D '0' + res
	return res

# Permute function to rearrange the bits


def permute(k, arr, n):
	permutation =3D ""
	for i in range(0, n):
		permutation =3D permutation + k[arr[i] - 1]
	return permutation

# shifting the bits towards left by nth shifts


def shift_left(k, nth_shifts):
	s =3D ""
	for i in range(nth_shifts):
		for j in range(1, len(k)):
			s =3D s + k[j]
		s =3D s + k[0]
		k =3D s
		s =3D ""
	return k

# calculating xow of two strings of binary number a and b


def xor(a, b):
	ans =3D ""
	for i in range(len(a)):
		if a[i] =3D=3D b[i]:
			ans =3D ans + "0"
		else:
			ans =3D ans + "1"
	return ans


