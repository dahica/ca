">import random
def gcd(a, b):
    while b !=3D 0:
        a, b =3D b, a % b
    return a

def generate_keypair(p, q):
    n =3D p * q
    phi =3D (p - 1) * (q - 1)
    e =3D random.randrange(1, phi)
    # print("e=3D",e)
    g =3D gcd(e, phi)
    while g !=3D 1:
        e =3D random.randrange(1, phi)
        g =3D gcd(e, phi)
    d =3D multiplicative_inverse(e, phi)
    return ((e, n), (d, n))

def multiplicative_inverse(e, phi):
    d =3D 0
    x1 =3D 0
    x2 =3D 1
    y1 =3D 1
    temp_phi =3D phi
    while e &gt; 0:
        temp1 =3D temp_phi // e
        temp2 =3D temp_phi - temp1 * e
        temp_phi =3D e
        e =3D temp2
        x =3D x2 - temp1 * x1
        y =3D d - temp1 * y1
        x2 =3D x1
        x1 =3D x
        d =3D y1
        y1 =3D y
    if temp_phi =3D=3D 1:
        return d + phi

def encrypt(public_key, plaintext):
    key, n =3D public_key
    cipher =3D [(ord(char) ** key) % n for char in plaintext]
    return cipher

def decrypt(private_key, ciphertext):
    key, n =3D private_key
    plain =3D [chr((char ** key) % n) for char in ciphertext]
    return ''.join(plain)


p =3D int(input("Enter first Prime No. .: "))
q =3D int(input("Enter Second Prime No.: "))
public_key, private_key =3D generate_keypair(p, q)

plaintext =3D input("Enter PlainText: ")
ciphertext =3D encrypt(public_key, plaintext)

decrypted_text =3D decrypt(private_key, ciphertext)

print("Plaintext:", plaintext)
print("Ciphertext:", ciphertext)
print("Decrypted text:", decrypted_text)</div></div><div class=3D"text-gray=
